{
	"name": "wp-feature-api",
	"version": "0.1.12",
	"description": "WordPress Feature API - System for exposing server and client-side functionality in WordPress for use in LLMs and agentic systems.",
	"author": "Automattic AI",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"api",
		"features",
		"llm",
		"ai"
	],
	"scripts": {
		"clean": "rimraf packages/client/build packages/client/build-types packages/client-features/build packages/demo-agent/build dist",
		"build": "npm run build --workspaces && npm run package",
		"build:client": "npm run build --workspace=packages/client",
		"build:client-features": "npm run build --workspace=packages/client-features",
		"build:demo-agent": "npm run build --workspace=packages/demo-agent",
		"build:all": "bash scripts/build.sh",
		"package": "powershell -ExecutionPolicy Bypass -File scripts/package.ps1",
		"package:bash": "bash scripts/package.sh",
		"verify": "bash scripts/verify-plugins.sh",
		"release": "bash scripts/release.sh",
		"test": "echo 'No tests configured'",
		"lint": "echo 'No linter configured'"
	},
	"workspaces": [
		"packages/client",
		"packages/client-features",
		"packages/demo-agent"
	],
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@wordpress/scripts": "^31.2.0",
		"@wordpress/dependency-extraction-webpack-plugin": "^6.10.0",
		"rimraf": "^6.0.1",
		"typescript": "^5.6.3",
		"webpack": "^5.95.0",
		"webpack-cli": "^5.1.4"
	}
}

