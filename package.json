{
	"name": "wp-feature-api",
	"version": "0.1.11",
	"description": "WordPress Feature API - System for exposing server and client-side functionality in WordPress for use in LLMs and agentic systems.",
	"author": "Automattic AI",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"api",
		"features",
		"llm",
		"ai"
	],
	"scripts": {
		"build": "npm run build --workspaces && npm run build --workspaces --if-present",
		"build:client": "npm run build --workspace=packages/client",
		"build:client-features": "npm run build --workspace=packages/client-features",
		"build:demo-agent": "npm run build --workspace=packages/demo-agent",
		"build:all": "./scripts/build.sh",
		"package": "./scripts/package.sh",
		"release": "./scripts/release.sh",
		"test": "echo 'No tests configured'",
		"lint": "echo 'No linter configured'"
	},
	"workspaces": [
		"packages/client",
		"packages/client-features",
		"packages/demo-agent"
	],
	"devDependencies": {
		"@types/node": "^20.0.0"
	}
}

