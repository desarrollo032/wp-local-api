{
  "name": "wp-feature-api",
  "version": "0.1.9",
  "description": "A system for exposing WordPress functionality in a standardized, discoverable way for both server and client-side use",
  "main": "src/index.js",
  "private": true,
  "workspaces": [
    "packages/*",
    "demo/*"
  ],
  "scripts": {
    "build": "npm run build:packages && wp-scripts build",
    "build:packages": "npm run build --workspaces --if-present",
    "format": "wp-scripts format",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "lint:packages": "npm run lint:js --workspaces --if-present",
    "packages-update": "wp-scripts packages-update",
    "plugin-zip": "wp-scripts plugin-zip",
    "start": "wp-scripts start",
    "env": "wp-env",
    "test:unit:php:setup": "wp-env start",
    "test:unit:php:setup:debug": "wp-env start --xdebug",
    "test:unit:php:base": "wp-env run --env-cwd='wp-content/plugins/wp-feature-api' tests-wordpress vendor/bin/phpunit -c phpunit.xml.dist --verbose",
    "test:unit:php": "npm-run-all test:unit:php:setup test:unit:php:base",
    "test:unit:php:debug": "npm-run-all test:unit:php:setup:debug test:unit:php:base",
    "serve": "wp-env start --xdebug",
    "wp-env": "wp-env",
    "clean": "npm run clean --workspaces --if-present && rm -rf build tsconfig.tsbuildinfo",
    "setup": "npm install && composer install"
  },
  "keywords": [
    "wordpress",
    "api",
    "features",
    "llm",
    "ai"
  ],
  "author": "Automattic",
  "homepage": "https://automattic.ai/",
  "license": "GPL-2.0-or-later",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@wordpress/api-fetch": "^6.60.0",
    "@wordpress/block-editor": "^15.0.0",
    "@wordpress/blocks": "^15.0.0",
    "@wordpress/commands": "^1.25.0",
    "@wordpress/components": "^27.30.0",
    "@wordpress/core-data": "^7.25.0",
    "@wordpress/data": "^9.35.0",
    "@wordpress/editor": "^15.0.0",
    "@wordpress/element": "^5.40.0",
    "@wordpress/i18n": "^4.65.0",
    "@wordpress/icons": "^10.30.0",
    "@wordpress/plugins": "^7.30.0",
    "@wp-feature-api/client-features": "^1.0.0",
    "node-fetch": "^3.3.2"
  },
  "prettier": "@wordpress/prettier-config",
  "devDependencies": {
    "@types/wordpress__block-editor": "^12.0.0",
    "@types/wordpress__blocks": "^13.0.0",
    "@types/wordpress__editor": "^15.0.0",
    "@wordpress/dependency-extraction-webpack-plugin": "^6.30.0",
    "@wordpress/env": "^10.25.0",
    "@wordpress/eslint-plugin": "^23.0.0",
    "@wordpress/prettier-config": "^4.25.0",
    "@wordpress/scripts": "^33.0.0",
    "eslint": "^8.60.0",
    "eslint-import-resolver-node": "^0.3.5",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-react-compiler": "^19.0.0-beta-aeaed83-20250323",
    "eslint-plugin-storybook": "^0.12.0",
    "npm-run-all": "^4.1.5",
    "prettier": "npm:wp-prettier@3.0.3"
  }
}
